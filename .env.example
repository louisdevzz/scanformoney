# Telegram Bot Configuration
TELEGRAM_BOT_TOKEN=your_bot_token_here
TELEGRAM_CHANNEL_ID=your_channel_id_here

# Scan Configuration
SCAN_INTERVAL_MINUTES=30
MAX_NOTIFICATIONS_PER_SCAN=1
MAX_ITEM_AGE_HOURS=24
MAX_BOUNTY_AGE_HOURS=48
MAX_HACKATHON_AGE_HOURS=120
SEND_SUMMARY_WHEN_NO_DETAILS=false

# Optional API keys for higher quality data
# Register an agent at https://superteam.fun/earn/agents to get API key
SUPERTEAM_AGENT_API_KEY=

# SQLite path (default: ./data/bounties.db)
# For Render Free plan, set to /tmp/bounties.db
SQLITE_DB_PATH=./data/bounties.db
